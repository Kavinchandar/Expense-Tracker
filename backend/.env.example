# Copy to .env and fill in from https://dashboard.plaid.com/ (Sandbox for dev)
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox

# Link institution region: IN for India (ICICI, etc.). Comma-separated for multiple, e.g. IN,US
PLAID_COUNTRY_CODES=IN

# For display / month context (IST for India)
DISPLAY_TIMEZONE=Asia/Kolkata
